{
  "name": "bodasesor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:redirects": "node scripts/generate-redirects.mjs",
    "guard:redirects": "node scripts/guard-redirects.mjs",
    "check:redirects": "node scripts/check-production-redirects.mjs",
    "build": "node scripts/guard-redirects.mjs && npm run generate:redirects && vite build && node scripts/verify-dist-assets.mjs && node scripts/verify-redirects-deploy.mjs",
    "build:netlify": "node scripts/netlify-build.mjs",
    "deploy:netlify": "node scripts/deploy-netlify.mjs",
    "build:safe": "node scripts/safe-build.mjs",
    "sync:netlify": "node scripts/pull-netlify-live.mjs",
    "merge:netlify": "node scripts/merge-live-into-dist.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/lato": "^5.2.7",
    "@fontsource/playfair-display": "^5.2.8",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "puppeteer-core": "^25.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
