# Copia a .env.local (no se sube a git)
NETLIFY_AUTH_TOKEN=tu_token_de_netlify
NETLIFY_SITE_ID=tu_api_id_del_sitio

# Google service account (Nexus indexador / Google Indexing API)
GOOGLE_APPLICATION_CREDENTIALS=private/credentials/nexus-ia-power-ef9a95a9817b.json
# Alternativa para scripts que leen el JSON como string:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Hostinger — para subir credenciales: bash scripts/upload-credentials-hostinger.sh
HOSTINGER_SSH=usuario@ip-del-vps
HOSTINGER_CREDENTIALS_PATH=/home/usuario/nexus/private/credentials/nexus-ia-power-ef9a95a9817b.json

# Obtener token: https://app.netlify.com/user/applications#personal-access-tokens
# Obtener site ID: Netlify → Site configuration → General → API ID
