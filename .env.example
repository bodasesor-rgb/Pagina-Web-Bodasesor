# Copia a .env.local (no se sube a git)
NETLIFY_AUTH_TOKEN=tu_token_de_netlify
NETLIFY_SITE_ID=tu_api_id_del_sitio
# Alternativa más fácil — solo dispara build desde Git (Netlify → Build hooks):
# NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/...

# Obtener token: https://app.netlify.com/user/applications#personal-access-tokens
# Obtener site ID: Netlify → Site configuration → General → API ID
